{
  "manifest_version": 3,
  "name": "AutoTrader Time Tracker",
  "version": "1.0.0",
  "description": "Track time spent on AutoTrader.com automatically",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.autotrader.co.uk/*",
    "https://autotrader.co.uk/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoTrader Time Tracker"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
